# Pegar las credenciales generadas en:
#   Jibble Web → Ajustes de la organización → Credenciales API → Crear nuevo secreto
# (El Secret solo se muestra 1 vez, guárdalo inmediatamente)
# Si dejas la CUENTA 1 vacía, el backend devuelve mock data realista.

# --- CUENTA 1 / Workspace A (obligatoria) ---
JIBBLE_API_KEY_ID=
JIBBLE_API_KEY_SECRET=

# --- CUENTA 2 / Workspace B (opcional: 2da cuenta para locales lejanos) ---
JIBBLE_API_KEY_ID_2=
JIBBLE_API_KEY_SECRET_2=

# --- CUENTA 3 / Workspace C (opcional) ---
# JIBBLE_API_KEY_ID_3=
# JIBBLE_API_KEY_SECRET_3=

# --- Nombres custom para el dropdown de cuentas (opcional, CSV en orden 1,2,3...) ---
# Si no se define, los workspaces se llaman "Workspace 1", "Workspace 2", etc.
# Ejemplo: JIBBLE_WORKSPACE_NAMES=Principal,Hüper Mall
JIBBLE_WORKSPACE_NAMES=

# Endpoints (no hace falta cambiarlos salvo que Jibble migre a otro dominio):
JIBBLE_TOKEN_URL=https://identity.prod.jibble.io/connect/token
JIBBLE_BASE_URL=https://workspace.prod.jibble.io/v1

PORT=3001
