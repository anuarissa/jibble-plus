# Pegar las 2 credenciales generadas en:
#   Jibble Web → Ajustes de la organización → Credenciales API → Crear nueva clave
# (Solo se muestran 1 vez, guárdalas inmediatamente)
# Si dejas estos vacíos, el backend devuelve mock data realista.
JIBBLE_API_KEY_ID=
JIBBLE_API_KEY_SECRET=

# Endpoints (no hace falta cambiarlos salvo que Jibble migre a otro dominio):
JIBBLE_TOKEN_URL=https://identity.prod.jibble.io/connect/token
JIBBLE_BASE_URL=https://workspace.prod.jibble.io/v1

PORT=3001
