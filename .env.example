# Variables a configurar en Vercel (Settings → Environment Variables)
# Local: copia este archivo a .env y rellena.

# === AUTH ===
# Contraseña para entrar a la app. Si la dejas vacía, la app es pública.
APP_PASSWORD=

# === JIBBLE (Settings → Credenciales API en Jibble web) ===
JIBBLE_API_KEY_ID=
JIBBLE_API_KEY_SECRET=

# Endpoints (no cambiar salvo migración Jibble)
JIBBLE_TOKEN_URL=https://identity.prod.jibble.io/connect/token
JIBBLE_BASE_URL=https://workspace.prod.jibble.io/v1
JIBBLE_TIME_BASE=https://time-tracking.prod.jibble.io/v1
