# Variables a configurar en Vercel (Settings → Environment Variables)
# Local: copia este archivo a .env y rellena.

# === AUTH ===
# Contraseña para entrar a la app. Si la dejas vacía, la app es pública.
APP_PASSWORD=

# === JIBBLE — CUENTA 1 / Workspace A (Settings → Credenciales API) ===
# Cuenta principal. Obligatoria.
JIBBLE_API_KEY_ID=
JIBBLE_API_KEY_SECRET=

# === JIBBLE — CUENTA 2 / Workspace B (opcional) ===
# 2da cuenta Jibble gratis, para locales lejanos con su propia geocerca.
# Generar en esa cuenta: Ajustes → Credenciales API → Crear nuevo secreto.
# Si quedan vacías, la app funciona solo con la cuenta 1 (igual que antes).
JIBBLE_API_KEY_ID_2=
JIBBLE_API_KEY_SECRET_2=

# === JIBBLE — CUENTA 3 / Workspace C (opcional, si hay 3ra ubicación lejana) ===
# JIBBLE_API_KEY_ID_3=
# JIBBLE_API_KEY_SECRET_3=

# Endpoints (no cambiar salvo migración Jibble)
JIBBLE_TOKEN_URL=https://identity.prod.jibble.io/connect/token
JIBBLE_BASE_URL=https://workspace.prod.jibble.io/v1
JIBBLE_TIME_BASE=https://time-tracking.prod.jibble.io/v1
